rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for registrations
    function isValidRegistration(data) {
      return data.keys().hasAll(['id', 'nombres', 'correo', 'telefono', 'ciudad', 'procedimiento', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.nombres is string && data.nombres.size() <= 150
        && data.correo is string && data.correo.size() <= 150
        && data.telefono is string && data.telefono.size() <= 50
        && data.ciudad is string && data.ciudad.size() <= 150
        && data.procedimiento is string && data.procedimiento.size() <= 150
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Registrations collection matches
    match /registrations/{registrationId} {
      allow get: if isValidId(registrationId);
      // Allow listing registrations
      allow list: if true;
      // Allow inserting new registrations
      allow create: if isValidId(registrationId) && isValidRegistration(request.resource.data);
      // Deny delete and update (registrations are immutable once made)
      allow update, delete: if false;
    }
  }
}
